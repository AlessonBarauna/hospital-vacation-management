{
  "ConnectionStrings": {
    "Database": "Host=localhost;Port=5432;Database=hospital_vacation_management;Username=postgres;Password=postgres"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
    }
  },
  "WriteTo": [
    {
      "Name": "Console"
    },
    {
      "Name": "File",
      "Args": {
        "path": "Logs/hospital-vacation-api-.log",
        "rollingInterval": "Day",
      }
    }
  ]
},
  "AllowedHosts": "*"
}